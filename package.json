{
  "name": "@agilehead/persona",
  "version": "0.0.1",
  "description": "OAuth authentication and identity management service",
  "type": "module",
  "private": true,
  "workspaces": [
    "node/packages/*"
  ],
  "scripts": {
    "build": "./scripts/build.sh",
    "clean": "./scripts/clean.sh",
    "start": "./scripts/start.sh",
    "test": "cd node/packages/persona-server && npm test",
    "test:grep": "cd node/packages/persona-server && npm run test:grep",
    "migrate:persona:latest": "knex migrate:latest --knexfile database/persona/knexfile.js",
    "migrate:persona:rollback": "knex migrate:rollback --knexfile database/persona/knexfile.js",
    "migrate:persona:status": "knex migrate:status --knexfile database/persona/knexfile.js",
    "migrate:persona:make": "knex migrate:make --knexfile database/persona/knexfile.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "chai": "^6.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "knex": "^3.1.0",
    "mocha": "^11.7.1",
    "prettier": "^3.4.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.19.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agilehead/persona.git"
  },
  "keywords": [
    "oauth",
    "authentication",
    "identity",
    "oidc",
    "typescript"
  ],
  "author": "Agilehead",
  "license": "MIT"
}
