{
  "name": "@agilehead/persona-server",
  "version": "0.0.1",
  "description": "OAuth authentication and identity management service",
  "type": "module",
  "main": "./dist/bin/server.js",
  "exports": {
    ".": {
      "import": "./dist/bin/server.js",
      "types": "./dist/bin/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin/server.ts",
    "start": "node dist/bin/server.js",
    "test": "NODE_OPTIONS='--import tsx' mocha tests/index.ts --timeout 60000",
    "test:grep": "NODE_OPTIONS='--import tsx' mocha tests/index.ts --timeout 60000 --grep",
    "test:build": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agilehead/persona-db": "file:../persona-db",
    "@agilehead/persona-logger": "file:../persona-logger",
    "@tinqerjs/better-sqlite3-adapter": "0.0.27",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "openid-client": "^6.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@agilehead/persona-test-utils": "file:../persona-test-utils",
    "@types/chai": "^5.2.3",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mocha": "^10.0.10",
    "@types/supertest": "^7.2.0",
    "chai": "^6.0.0",
    "mocha": "^11.7.1",
    "supertest": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0"
  }
}
